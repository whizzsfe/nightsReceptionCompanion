# Night Receptionist Companion Suite — .gitignore

# Property-specific override files (generated by hotelcompanion_editor.html)
# These contain hotel-specific content and must not be committed to the repo.
# Place the exported files in the same folder as hotelcompanion_suite.html on OneDrive.
hotelcompanion_items.js
hotelcompanion_scripts.js
hotelcompanion_config.js
hotelcompanion_wiki.js

# License file — generated by scripts/generate-license.js for each client property.
# Never commit a client license file to the repo.
hotelcompanion_license.js

# RSA-PSS key pair — generated once by scripts/generate-license.js --keygen.
# NEVER commit these. The private key is required to sign license files.
scripts/private-key.pem
scripts/public-key.pem

# Electron build output
dist/
node_modules/
app/hotelcompanion_suite.html
app/hotelcompanion_editor.html
app/hotelLogo.jpg
app/hotelLogo.ico

# OS & editor noise
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.vscode/settings.json


# builds save for use - not for committing
builds/
originals/
hotelcompanion_rota.json
